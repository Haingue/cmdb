# Kafka Configuration - Optional environment variables
# Copy this file to .env to override default values

# Docker Compose project name (default: directory name)
COMPOSE_PROJECT_NAME=cmdb

# Kafka Cluster ID (must be same for all brokers in a cluster)
KAFKA_CLUSTER_ID=cmdb-kafka-cluster

# Kafka data retention settings (in milliseconds)
# 7 days = 604800000
# 30 days = 2592000000
KAFKA_LOG_RETENTION_MS=604800000

# Kafka heap settings
KAFKA_HEAP_OPTS=-Xmx512M -Xms512M

# Kafka topics to create on startup (format: topic:partitions:replication:retention_ms)
# Format: "topic_name:partitions:replication_factor[:retention_ms]"
# Example: "custom-topic:3:2:604800000,my-queue:1:2"
# - retention_ms is optional (default: 604800000 = 7 days)
# - Separate multiple topics with commas
KAFKA_CREATE_TOPICS=topic1:partitions:replication:retention_ms,topic2:partitions:replication:retention_ms